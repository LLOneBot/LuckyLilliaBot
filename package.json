  "version": "8.0.0",
  "type": "module",
  "description": "",
  "main": "dist/llbot.js",
  "scripts": {
    "dev": "tsx watch src/main/main.ts",
    "build": "vite build",
    "dev-webui": "npm --prefix src/webui/FE run dev",
    "build-webui": "npm --prefix src/webui/FE run build",
    "postinstall": "npm --prefix src/webui/FE install",
    "format": "prettier -cw .",
    "check": "tsc",
    "check:webui": "npm --prefix src/webui/FE run check",
    "test:webui": "vitest run --config vitest.config.ts 'test/webui'",
    "test:unit": "vitest run --config vitest.config.ts 'test/unit'",
    "test": "vitest run --config vitest.config.ts"
  },
