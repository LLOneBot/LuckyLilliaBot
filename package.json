    "@cordisjs/plugin-timer": "^1.1.2",
    "@hono/node-server": "^2.0.10",
    "@saltify/typeproto": "^0.4.1",
    "@satorijs/element": "^3.2.0",
    "@satorijs/protocol": "^1.7.0",
    "compare-versions": "^6.1.1",
    "cordis": "4.0.0-rc.7",
    "cosmokit": "^1.8.1",
    "fast-xml-parser": "^5.10.1",
