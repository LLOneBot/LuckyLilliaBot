{
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@common/types": ["../../common/types"],
      "@ntqqapi/types": ["../../ntqqapi/types"],
      "@/common/types": ["../../common/types"],
      "@/ntqqapi/types": ["../../ntqqapi/types"],
      "@/*": ["./*"]
    },
    "types": ["vite/client"],
    "jsx": "react",
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler",
    "module": "esnext",
    "noEmit": true
  },
  "include": [
    "./**/*",
    "../../common/types.ts",
    "../../ntqqapi/types/**/*",
    "../../version.ts",
    "../../main/config/defaultConfig.ts",
    "../BE/types.ts"
  ],
  "exclude": ["node_modules"]
}
